{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "prompt-library-viewer",
  "version": "0.1.0",
  "identifier": "com.xc1500225328.promptlibraryviewer",
  "build": {
    "frontendDist": "../public",
    "devUrl": null,
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Prompt Library Viewer",
        "width": 1720,
        "height": 1120,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
